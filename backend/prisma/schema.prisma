generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeaveStatus {
  BROUILLON
  EN_ATTENTE_RH
  EN_ATTENTE_DIRECTION
  AVIS_RH_RENDU
  APPROUVE
  REFUSE
  ANNULE
}

enum CampaignStatus {
  BROUILLON
  OUVERTE
  CLOTUREE
}

enum ProposalStatus {
  RECUE
  EN_ANALYSE
  ACCEPTEE
  REPROGRAMMEE
  REFUSEE
}

enum NotificationType {
  LEAVE_CREATED
  LEAVE_RH_REVIEWED
  LEAVE_DECIDED
  LEAVE_TRANSMITTED
  LEAVE_CANCELLED
  PERMISSION_CREATED
  PERMISSION_RH_REVIEWED
  PERMISSION_DECIDED
  USER_CREATED
  USER_ACTIVATED
  USER_DEACTIVATED
  USER_MODIFIED
  EMPLOYEE_CREATED
  EMPLOYEE_MODIFIED
  DEPARTMENT_CREATED
  POSITION_CREATED
  LEAVE_TYPE_CREATED
  HOLIDAY_ADDED
  CAMPAIGN_OPENED
  INFO
}

enum InternalEventType {
  SEMINAIRE
  AUDIT
  INVENTAIRE
  FORMATION
  REUNION_STRATEGIQUE
  FERMETURE_ANNUELLE
  MAINTENANCE
  AUTRE
}

enum InternalEventPriority {
  FAIBLE
  MOYENNE
  HAUTE
  CRITIQUE
}

enum InternalEventStatus {
  BROUILLON
  ACTIF
  ARCHIVE
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?

  users       User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  firstName          String?
  lastName           String?
  gender             String?
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(true)
  welcomeSent        Boolean   @default(false)
  resetToken         String?
  resetTokenExpires  DateTime?

  roleId    Int
  role      Role     @relation(fields: [roleId], references: [id])

  employee  Employee?

  hrReviewedLeaves        LeaveRequest[]       @relation("HR_Review")
  directorDecidedLeaves   LeaveRequest[]       @relation("Director_Decision")
  hrReviewedPermissions   PermissionRequest[]  @relation("Permission_HR_Review")
  directorDecidedPermissions PermissionRequest[] @relation("Permission_Director_Decision")

  annualLeavePlannings  AnnualLeavePlanning[]

  notifications Notification[]
  auditLogs     AuditLog[]
  balanceAdjustments BalanceAdjustment[]
  decisionAnalysesCreated DecisionAnalysis[] @relation("DecisionCreator")
  decisionAnalysesDecided DecisionAnalysis[] @relation("DecisionDecider")
  leaveRequestHistories LeaveRequestHistory[]
  passwordResetOtps PasswordResetOtp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetOtp {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([otp])
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  headId      Int?     @unique
  head        Employee? @relation("DepartmentHead", fields: [headId], references: [id])
  isActive    Boolean  @default(true)
  minEmployees Int     @default(0)

  employees   Employee[]
  positions   Position[]
  internalEvents InternalEvent[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Position {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  isActive    Boolean  @default(true)
  isCritical  Boolean  @default(false)
  canBeReplaced Boolean @default(true)
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])

  employees   Employee[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, departmentId])
}

model Employee {
  id           Int      @id @default(autoincrement())
  matricule    String   @unique
  firstName    String
  lastName     String
  hireDate     DateTime
  position     String?
  positionId   Int?
  positionRef  Position? @relation(fields: [positionId], references: [id])

  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id])

  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])

  headedDepartment Department? @relation("DepartmentHead")

  leaveRequests          LeaveRequest[]
  permissionRequests     PermissionRequest[]
  leaveBalances          LeaveBalance[]
  annualLeavePlannings   AnnualLeavePlanning[]
  leaveProposals         LeaveProposal[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LeaveType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  defaultDays Int      @default(0)
  isActive    Boolean  @default(true)

  requiresRhValidation       Boolean  @default(true)
  requiresDirectorValidation Boolean  @default(false)
  requiresJustification      Boolean  @default(false)
  deductsFromAnnualBalance   Boolean  @default(true)
  maxDuration                Int?
  minDuration                Int?
  color                      String   @default("#0B6B3A")
  icon                       String   @default("Calendar")

  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AnnualLeavePlanning {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  employee    Employee @relation(fields: [employeeId], references: [id])
  year        Int
  month       Int

  plannedById Int
  plannedBy   User     @relation(fields: [plannedById], references: [id])

  leaveRequests LeaveRequest[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([employeeId, year])
  @@index([employeeId])
  @@index([year])
}

model LeaveRequest {
  id             Int         @id @default(autoincrement())
  startDate      DateTime
  endDate        DateTime
  duration       Int
  reason         String
  status         LeaveStatus @default(EN_ATTENTE_RH)
  hrComment      String?
  hrOpinion      String?
  directorComment String?
  reviewedAt     DateTime?
  decidedAt      DateTime?

  employeeId     Int
  employee       Employee @relation(fields: [employeeId], references: [id])

  leaveTypeId    Int
  leaveType      LeaveType @relation(fields: [leaveTypeId], references: [id])

  annualLeavePlanningId Int
  annualLeavePlanning  AnnualLeavePlanning @relation(fields: [annualLeavePlanningId], references: [id])

  reviewedById   Int?
  reviewedBy     User?    @relation("HR_Review", fields: [reviewedById], references: [id])

  decidedById    Int?
  decidedBy      User?    @relation("Director_Decision", fields: [decidedById], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  histories    LeaveRequestHistory[]

  @@index([employeeId])
  @@index([status])
  @@index([annualLeavePlanningId])
}

model LeaveRequestHistory {
  id             Int         @id @default(autoincrement())
  previousStatus String?
  newStatus      String
  comment        String?
  userId         Int
  user           User        @relation(fields: [userId], references: [id])
  leaveRequestId Int
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())

  @@index([leaveRequestId])
}

model PermissionRequest {
  id             Int         @id @default(autoincrement())
  startDate      DateTime
  endDate        DateTime
  duration       Int
  reason         String
  status         LeaveStatus @default(EN_ATTENTE_RH)
  hrComment      String?
  hrOpinion      String?
  directorComment String?
  reviewedAt     DateTime?
  decidedAt      DateTime?

  employeeId     Int
  employee       Employee @relation(fields: [employeeId], references: [id])

  reviewedById   Int?
  reviewedBy     User?    @relation("Permission_HR_Review", fields: [reviewedById], references: [id])

  decidedById    Int?
  decidedBy      User?    @relation("Permission_Director_Decision", fields: [decidedById], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
}

model LeaveBalance {
  id           Int   @id @default(autoincrement())
  year         Int
  totalDays    Int   @default(0)
  adjustedDays Int   @default(0)
  usedDays     Int   @default(0)
  pendingDays  Int   @default(0)
  status       String @default("ACTIF")

  employeeId   Int
  employee     Employee @relation(fields: [employeeId], references: [id])

  leaveTypeId  Int
  leaveType    LeaveType @relation(fields: [leaveTypeId], references: [id])

  adjustments BalanceAdjustment[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
}

model BalanceAdjustment {
  id                Int      @id @default(autoincrement())
  operationType     String
  previousRemaining Int      @default(0)
  newRemaining      Int      @default(0)
  comment           String?

  leaveBalanceId    Int
  leaveBalance      LeaveBalance @relation(fields: [leaveBalanceId], references: [id])

  authorId          Int
  author            User     @relation(fields: [authorId], references: [id])

  createdAt         DateTime @default(now())

  @@index([leaveBalanceId])
}

model Notification {
  id         Int              @id @default(autoincrement())
  title      String
  message    String
  isRead     Boolean          @default(false)
  type       NotificationType
  link       String?
  entityType String?
  entityId   Int?

  userId     Int
  user       User             @relation(fields: [userId], references: [id])

  createdAt  DateTime         @default(now())

  @@index([userId, isRead])
  @@index([entityType, entityId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  entityType String
  entityId   Int
  oldValue   Json?
  newValue   Json?

  userId     Int
  user       User     @relation(fields: [userId], references: [id])

  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

model Holiday {
  id          Int      @id @default(autoincrement())
  name        String
  date         DateTime
  isRecurring Boolean  @default(false)
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, date])
}

model DecisionAnalysis {
  id                Int      @id @default(autoincrement())
  entityType        String   // 'LEAVE_REQUEST' | 'LEAVE_PROPOSAL'
  entityId          Int
  score             Int
  maxScore          Int      @default(100)
  rules             Json     // RuleEvaluation[]
  summary           String?
  suggestedStartDate DateTime?
  suggestedEndDate   DateTime?
  suggestionNote    String?
  decision          String?  // 'ACCEPT' | 'REJECT' | 'MODIFY'
  decisionComment   String?
  decidedAt         DateTime?

  createdById       Int
  createdBy         User     @relation("DecisionCreator", fields: [createdById], references: [id])
  decidedById       Int?
  decidedBy         User?    @relation("DecisionDecider", fields: [decidedById], references: [id])

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([entityType, entityId])
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeaveCampaign {
  id        Int             @id @default(autoincrement())
  year      Int             @unique
  label     String
  status    CampaignStatus  @default(BROUILLON)

  proposals LeaveProposal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeaveProposal {
  id               Int             @id @default(autoincrement())
  desiredStartDate DateTime
  duration         Int             @default(0)
  comment          String?
  status           ProposalStatus  @default(RECUE)

  analysisStatus   String?         @default("PENDING")
  analysisDetails  Json?
  suggestedStartDate DateTime?
  suggestedEndDate   DateTime?

  campaignId       Int
  campaign         LeaveCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  employeeId       Int
  employee         Employee        @relation(fields: [employeeId], references: [id])

  analysisLogs     ProposalAnalysisLog[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([campaignId, employeeId])
  @@index([campaignId])
  @@index([employeeId])
}

model ProposalAnalysisLog {
  id         Int      @id @default(autoincrement())
  action     String
  details    String?

  proposalId Int
  proposal   LeaveProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@index([proposalId])
}

model InternalEvent {
  id          Int                   @id @default(autoincrement())
  title       String
  description String?
  type        InternalEventType     @default(AUTRE)
  startDate   DateTime
  endDate     DateTime
  allCompany  Boolean               @default(true)
  priority    InternalEventPriority @default(MOYENNE)
  status      InternalEventStatus   @default(BROUILLON)

  departmentId Int?
  department   Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([startDate, endDate])
  @@index([departmentId])
}
