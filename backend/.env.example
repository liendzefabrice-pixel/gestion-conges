# ===========================
# Application
# ===========================
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ===========================
# Database
# ===========================
DATABASE_URL="postgresql://postgres:password@localhost:5432/gestion_conges_db"

# ===========================
# JWT
# ===========================
JWT_SECRET=change_this_secret_key
JWT_EXPIRES_IN=1d

# ===========================
# SMTP (Email)
# ===========================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@siap-pharma.com

# ===========================
# OTP (Password reset)
# ===========================
OTP_EXPIRATION_MINUTES=10
OTP_RESEND_DELAY_SECONDS=60
OTP_MAX_REQUESTS=3
OTP_RATE_LIMIT_WINDOW_MINUTES=15
